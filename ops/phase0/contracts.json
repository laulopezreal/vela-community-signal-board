{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vela-community-signal-board.local/contracts/phase0.json",
  "title": "Checkpoint #1 Phase0 Contracts",
  "type": "object",
  "required": ["DiscordRawEvent", "NormalizedSignal", "DecisionOutput"],
  "properties": {
    "DiscordRawEvent": {
      "type": "object",
      "required": ["id", "createdAt", "content"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "threadId": { "type": "string" },
        "channel": { "type": "string" },
        "author": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "reactionCount": { "type": "integer", "minimum": 0 },
        "content": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "NormalizedSignal": {
      "type": "object",
      "required": [
        "signalId",
        "externalId",
        "threadId",
        "source",
        "title",
        "content",
        "createdAt",
        "urgency",
        "relevance",
        "confidence",
        "score"
      ],
      "properties": {
        "signalId": { "type": "string" },
        "externalId": { "type": "string" },
        "threadId": { "type": "string" },
        "source": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "owner": { "type": "string" },
        "urgency": { "type": "integer", "minimum": 1, "maximum": 5 },
        "relevance": { "type": "integer", "minimum": 1, "maximum": 5 },
        "confidence": { "type": "integer", "minimum": 1, "maximum": 5 },
        "score": { "type": "number" },
        "weighted": { "type": "number" },
        "revenue": { "type": "integer", "minimum": 1, "maximum": 5 },
        "product": { "type": "integer", "minimum": 1, "maximum": 5 },
        "risk": { "type": "integer", "minimum": 1, "maximum": 5 },
        "leverage": { "type": "integer", "minimum": 1, "maximum": 5 }
      },
      "additionalProperties": true
    },
    "DecisionOutput": {
      "type": "object",
      "required": ["decisionId", "signalId", "owner", "action", "weightedScore"],
      "properties": {
        "decisionId": { "type": "string" },
        "signalId": { "type": "string" },
        "owner": { "type": "string" },
        "action": { "type": "string" },
        "deadline": { "type": "string", "format": "date-time" },
        "expectedMetric": { "type": "string" },
        "weightedScore": { "type": "number" }
      },
      "additionalProperties": true
    }
  }
}
