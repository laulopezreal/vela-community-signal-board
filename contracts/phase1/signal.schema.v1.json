{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "petalos://contracts/phase1/signal.schema.v1.json",
  "title": "Phase1 Inbound Event Contract v1",
  "type": "object",
  "required": ["provider", "event_type", "id", "content", "channel", "createdAt"],
  "properties": {
    "provider": { "type": "string", "enum": ["discord"] },
    "event_type": { "type": "string", "enum": ["message"] },
    "id": { "type": "string", "minLength": 1 },
    "content": { "type": "string", "minLength": 1 },
    "channel": { "type": "string", "minLength": 1 },
    "threadId": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": true
}
